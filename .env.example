# VCloud environment configuration
# Copy to `--dart-define=...` flags when running or building.
#
# Examples for dev:
#   flutter run \
#     --dart-define=VCLOUD_SUPABASE_URL=https://your-project.supabase.co \
#     --dart-define=VCLOUD_SUPABASE_ANON_KEY=sb_publishable__XXXXX
#
# The SECRET key (`sb_secret_*`) MUST NEVER go into the client app or
# any source-controlled file — it bypasses Row Level Security.

VCLOUD_SUPABASE_URL=https://your-project.supabase.co
VCLOUD_SUPABASE_ANON_KEY=sb_publishable_XXXXX
